<section id="contact" class="bg-white border-t border-border">
  <div class="max-w-[1120px] mx-auto px-6 py-16 lg:px-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-16 items-end">

      <div>
        <h2 class="text-[32px] lg:text-4xl font-bold tracking-[-0.02em] text-dark mt-0 mb-8">
          Contact
        </h2>
        <p class="text-[56px] lg:text-[88px] font-bold leading-none tracking-[-0.04em] text-dark mt-0 mb-7">
          Let's talk.
        </p>
        <p class="text-lg leading-[1.6] text-text-secondary mt-0 max-w-[40ch]">
          Based in Puebla, Mexico — CST (UTC−6).
        </p>
      </div>

      <div class="flex flex-col gap-10 lg:pt-2">
        <a
          href="mailto:hello@marcocarmona.dev"
          class="text-xl font-semibold text-dark no-underline border-b-2 border-accent pb-1 inline-block break-all hover:text-accent transition-colors"
        >
          hello@marcocarmona.dev
        </a>

        <div class="flex gap-2.5 items-center flex-wrap">
          <a
            href="https://www.linkedin.com/in/marcocarmonadev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="flex items-center gap-2 h-11 px-4 border-[1.5px] border-border rounded-md bg-transparent text-text-secondary no-underline hover:border-dark hover:text-dark transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4.5 3C3.67 3 3 3.67 3 4.5S3.67 6 4.5 6 6 5.33 6 4.5 5.33 3 4.5 3zM3 7.5h3V17H3V7.5zM7.5 7.5h2.9v1.3h.04c.4-.76 1.38-1.55 2.84-1.55C16 7.25 17 8.9 17 11.5V17h-3v-5c0-1.2-.02-2.74-1.67-2.74-1.68 0-1.93 1.31-1.93 2.65V17H7.5V7.5z" fill="currentColor"></path>
            </svg>
            <span class="text-sm font-medium">LinkedIn</span>
          </a>
          <a
            href="https://github.com/marcocarmonadev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="flex items-center gap-2 h-11 px-4 border-[1.5px] border-border rounded-md bg-transparent text-text-secondary no-underline hover:border-dark hover:text-dark transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M10 2C5.58 2 2 5.58 2 10c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0018 10c0-4.42-3.58-8-8-8z" fill="currentColor"></path>
            </svg>
            <span class="text-sm font-medium">GitHub</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
