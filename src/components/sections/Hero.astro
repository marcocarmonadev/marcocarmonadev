---
---

<section class="bg-dark flex items-center min-h-[680px]">
  <div class="max-w-[1120px] w-full mx-auto px-6 py-12 lg:px-16 lg:py-[120px]">
    <div class="grid grid-cols-1 lg:grid-cols-[1.25fr_0.75fr] gap-6 lg:gap-16 items-center">

      <div>
        <div class="text-[13px] font-bold tracking-[0.08em] uppercase text-accent-light mb-5">
          Fullstack Software Engineer
        </div>
        <h1 class="text-[44px] lg:text-[72px] font-bold leading-none tracking-[-0.03em] text-white mt-0 mb-4 lg:mb-6">
          Marco Carmona
        </h1>
        <p class="text-[22px] lg:text-2xl font-bold leading-[1.45] text-white mt-0 mb-4 lg:mb-5 max-w-[34ch]">
          Backend-first engineer with depth in infrastructure, ML, and full-stack delivery.
        </p>
        <div class="font-mono text-[12px] lg:text-[13px] font-medium tracking-[0.08em] uppercase text-white/55 mb-7 lg:mb-9">
          Available for new roles · Remote · Puebla · CDMX
        </div>

        <div class="flex flex-col gap-3 lg:flex-row lg:gap-3.5 lg:flex-wrap lg:items-center">
          <a
            href="/Marco_Carmona_resume.pdf"
            download="Marco_Carmona_resume.pdf"
            class="text-center lg:text-left text-base font-semibold bg-white text-dark no-underline px-7 py-3.5 rounded-md border-[1.5px] border-white whitespace-nowrap hover:bg-white/88 transition-colors"
          >
            Download CV
          </a>
          <div class="flex gap-2 items-center">
            <a
              href="https://www.linkedin.com/in/marcocarmonadev"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="flex items-center justify-center flex-1 lg:flex-none lg:w-12 h-12 border-[1.5px] border-white/18 rounded-md bg-transparent text-white/50 no-underline hover:border-white/70 hover:text-white transition-colors"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4.5 3C3.67 3 3 3.67 3 4.5S3.67 6 4.5 6 6 5.33 6 4.5 5.33 3 4.5 3zM3 7.5h3V17H3V7.5zM7.5 7.5h2.9v1.3h.04c.4-.76 1.38-1.55 2.84-1.55C16 7.25 17 8.9 17 11.5V17h-3v-5c0-1.2-.02-2.74-1.67-2.74-1.68 0-1.93 1.31-1.93 2.65V17H7.5V7.5z" fill="currentColor"></path>
              </svg>
            </a>
            <a
              href="https://github.com/marcocarmonadev"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class="flex items-center justify-center flex-1 lg:flex-none lg:w-12 h-12 border-[1.5px] border-white/18 rounded-md bg-transparent text-white/50 no-underline hover:border-white/70 hover:text-white transition-colors"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M10 2C5.58 2 2 5.58 2 10c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0018 10c0-4.42-3.58-8-8-8z" fill="currentColor"></path>
              </svg>
            </a>
            <a
              href="mailto:hello@marcocarmona.dev"
              aria-label="Email"
              class="flex items-center justify-center flex-1 lg:flex-none lg:w-12 h-12 border-[1.5px] border-white/18 rounded-md bg-transparent text-white/50 no-underline hover:border-white/70 hover:text-white transition-colors"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M3 5.5A1.5 1.5 0 014.5 4h11A1.5 1.5 0 0117 5.5v9a1.5 1.5 0 01-1.5 1.5h-11A1.5 1.5 0 013 14.5v-9zm1.5-.5a.5.5 0 00-.5.5v.42l6 4 6-4V5.5a.5.5 0 00-.5-.5h-11zm11 1.98l-5.43 3.62a1 1 0 01-1.14 0L4 6.98V14.5a.5.5 0 00.5.5h11a.5.5 0 00.5-.5V6.98z" fill="currentColor"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="aspect-square rounded-[10px] overflow-hidden">
        <img
          src="/images/portfolio_headshot_enhanced.jpg"
          alt="Marco Carmona"
          class="w-full h-full object-cover object-top block"
        />
      </div>

    </div>
  </div>
</section>
