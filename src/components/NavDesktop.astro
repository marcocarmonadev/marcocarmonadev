---
import { navLinks } from "../data/navLinks";
---

<nav
  id="nav-desktop"
  class="hidden md:flex fixed top-0 left-0 right-0 z-10 justify-center pointer-events-none"
  aria-label="Desktop navigation"
>
  <div
    id="nav-pill"
    class="pointer-events-auto flex items-center gap-1 rounded-full px-1.5 py-1.5"
  >
    {
      navLinks.map(({ href, label }) => (
        <a
          href={href}
          data-nav-link={href.slice(1)}
          class="nav-link text-sm font-medium text-text-secondary no-underline px-4 py-2 rounded-full"
        >
          {label}
        </a>
      ))
    }
    <a
      href="#contact"
      data-nav-link="contact"
      class="nav-link-contact text-sm font-semibold text-white bg-accent no-underline px-5 py-2 rounded-full transition-colors hover:bg-accent-dark"
    >
      Contact
    </a>
  </div>
</nav>

<style>
  #nav-desktop {
    transition: top 0.35s ease;
  }

  #nav-desktop.is-scrolled {
    top: 20px;
  }

  #nav-pill {
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition:
      background 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }

  #nav-pill.is-scrolled {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: rgba(0, 0, 0, 0.07);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .nav-link {
    color: #5b6470;
    text-decoration: none;
    transition:
      color 0.25s ease,
      background 0.25s ease;
  }

  .nav-link:hover {
    color: #111317;
    background: #f4f5f7;
  }

  .nav-link.is-active {
    color: oklch(42% 0.18 258);
    background: oklch(96% 0.02 258);
    font-weight: 600;
  }
</style>

<script>
  const nav = document.getElementById("nav-desktop")!;
  const pill = document.getElementById("nav-pill")!;
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const sections = Array.from(links)
    .map((a) => document.getElementById(a.dataset.navLink!))
    .filter(Boolean) as HTMLElement[];

  // --- Scrolled state ---
  function onScroll() {
    const scrolled = window.scrollY > 60;
    pill.classList.toggle("is-scrolled", scrolled);
    nav.classList.toggle("is-scrolled", scrolled);
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // --- Active section tracking ---
  const sectionIds = sections.map((s) => s.id);
  function getActive() {
    const trigger = window.scrollY + window.innerHeight * 0.35;
    let active = "";
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el) {
        const top = el.getBoundingClientRect().top + window.scrollY;
        if (top <= trigger) active = id;
      }
    }
    return active;
  }

  function setActive(id: string) {
    links.forEach((a) => {
      if (a.classList.contains("nav-link-contact")) return;
      a.classList.toggle("is-active", a.dataset.navLink === id);
    });
  }

  window.addEventListener(
    "scroll",
    () => setActive(getActive()),
    { passive: true }
  );
  setActive(getActive());
</script>
